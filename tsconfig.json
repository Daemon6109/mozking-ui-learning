{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"allowImportingTsExtensions": true,
		"types": ["bun"]
	},
	"include": ["src/**/*.ts", "tests/**/*.ts", "quests/**/*.ts"],
	"exclude": ["roblox-ts-sandbox"]
}
