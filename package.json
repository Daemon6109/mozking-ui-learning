{
	"name": "mozking-ui-learning",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.14",
	"workspaces": [
		"roblox-ts-sandbox"
	],
	"scripts": {
		"check": "bun run check:node && bun run roblox:compile && bun run compose:check && bun run yaml:check",
		"check:node": "bun run typecheck && bun run lint && bun run cspell && bun test",
		"compose:check": "docker compose config --quiet",
		"yaml:check": "! rg -nP '^\\t' . --glob '*.yml' --glob '*.yaml' --glob '!node_modules/**' --glob '!roblox-ts-sandbox/node_modules/**'",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"format:check": "biome format . && bun run yaml:check",
		"format:write": "biome format . --write",
		"cspell": "cspell . --no-progress",
		"quest:01": "bun test quests/01-js-basics",
		"quest:02": "bun test quests/02-typescript",
		"quest:03": "bun test quests/03-ui-data",
		"quest:04": "bun test quests/04-reactive-ui",
		"quest:05": "bun test quests/05-roblox-ts-vide",
		"quests": "bun run quest:01 && bun run quest:02 && bun run quest:03 && bun run quest:04 && bun run quest:05",
		"roblox:compile": "bun run --filter mozking-roblox-ts-sandbox compile",
		"roblox:watch": "bun run --filter mozking-roblox-ts-sandbox watch"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@types/bun": "^1.3.14",
		"cspell": "^10.0.1",
		"typescript": "=5.5.3"
	}
}
