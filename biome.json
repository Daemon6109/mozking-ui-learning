{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"formatter": {
		"enabled": true,
		"lineWidth": 120,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "warn",
				"noUnusedVariables": "warn"
			},
			"style": {
				"useConst": "warn",
				"noNonNullAssertion": "warn",
				"useImportType": "warn"
			},
			"suspicious": {
				"noExplicitAny": "warn"
			}
		}
	},
	"files": {
		"includes": [
			"**/*.{ts,tsx,js,jsx,json,md}",
			"!node_modules",
			"!dist",
			"!**/*.tsbuildinfo"
		]
	}
}
